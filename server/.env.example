# Copy to .env and fill in values before starting the server

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/flowprint

# Secret used to sign JWTs — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the API listens on (default 3001)
PORT=3001

# Allowed CORS origin — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173
